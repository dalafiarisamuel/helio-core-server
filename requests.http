### Health
GET http://localhost:8080/health

### Register user
POST http://localhost:8080/auth/register
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "Passw0rd!"
}

### Login user
POST http://localhost:8080/auth/login
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "Passw0rd!"
}
> {% 
    client.global.set("jwt", response.body.token); 
    client.global.set("refresh_token", response.body.refresh_token);
%}

### Refresh Token
POST http://localhost:8080/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refresh_token}}"
}
> {% 
    client.global.set("jwt", response.body.token); 
    client.global.set("refresh_token", response.body.refresh_token);
%}

### Get current user details
GET http://localhost:8080/auth/me
Authorization: Bearer {{jwt}}

### Solar potential - Lagos, Nigeria (PVWatts)
POST http://localhost:8080/solar/potential
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "latitude": 6.5244,
  "longitude": 3.3792,
  "panel_wattage": 1000,
  "panel_count": 1,
  "panel_tilt": 20,
  "azimuth": 180
}

### Solar estimate - Lagos, Nigeria (uses PVWatts internally)
POST http://localhost:8080/solar/estimate
Authorization: Bearer {{jwt}}
Content-Type: application/json

{
  "latitude": 6.5244,
  "longitude": 3.3792,
  "panel_wattage": 450,
  "panel_count": 12
}

